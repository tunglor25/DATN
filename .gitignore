# Laravel default ignore rules
/vendor
/node_modules
/public/storage
/storage/*
/bootstrap/cache/

# Ignore environment files
.env
.env.*.php

# IDEs and editors
.idea
*.sublime-project
*.sublime-workspace
*.vscode

# System files
.DS_Store
Thumbs.db

# Composer PHAR
composer.phar

# NPM/Yarn logs
npm-debug.log
yarn-debug.log
yarn-error.log

# Laravel Horizon & Telescope logs (optional)
horizon.log
telescope.log

# Nhưng giữ lại đường dẫn này:
!/storage/app
!/storage/app/public
!/storage/app/public/img
!/storage/app/public/img/**
